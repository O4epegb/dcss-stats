datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma/client"
  previewFeatures = []
}

model Server {
  id           String    @id @default(cuid())
  name         String    @unique
  abbreviation String    @unique
  url          String    @unique
  baseUrl      String
  morgueUrl    String?
  ttyrecUrl    String?
  logfile      Logfile[]
  isDormant    Boolean   @default(false)
}

model Logfile {
  id              String   @id @default(cuid())
  path            String
  version         String
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id])
  game            Game[]
  lastFetched     DateTime @default(now())
  bytesRead       Int      @default(0)
  morgueUrlPrefix String?

  InvalidGame InvalidGame[]

  @@unique([serverId, path])
}

model Player {
  id      String   @id
  name    String   @unique
  game    Game[]
  isBot   Boolean  @default(false)
  streaks    Streak[]
  highscores Highscore[]
}

model Game {
  id                 String       @id
  isWin              Boolean
  startAt            DateTime
  endAt              DateTime
  version            String
  versionShort       String
  versionInteger     Int          @default(0)
  score              Int
  xl                 Int
  race               String
  class              String
  normalizedRace     String
  normalizedClass    String?
  raceAbbr           String
  classAbbr          String
  char               String
  title              String
  endMessage         String
  turns              Int
  duration           Int
  uniqueRunes        Int
  runes              Int
  gems               Int          @default(0)
  intactGems         Int          @default(0)
  branch             String
  lvl                Int
  fifteenskills      String[]
  maxskills          String[]
  name               String
  str                Int
  int                Int
  dex                Int
  ac                 Int?
  ev                 Int?
  sh                 Int?
  god                String?
  piety              Int?
  killer             String?
  killerType         String?
  scrollsused        Int?
  potionsused        Int?
  gold               Int?
  goldfound          Int?
  goldspent          Int?
  playerId           String
  player             Player       @relation(fields: [playerId], references: [id])
  logfileId          String
  logfile            Logfile      @relation(fields: [logfileId], references: [id])
  serverAbbreviation String?
  streakGames        StreakGame[]
  highscores         Highscore[]

  @@index([playerId, startAt])
  @@index([playerId, endAt])
  @@index([startAt])
  @@index([endAt])
  @@index([versionShort])
  @@index([versionInteger, endAt])
  @@index([normalizedClass])
  @@index([normalizedRace])
  @@index([god])
  @@index([isWin])
  @@index([serverAbbreviation, endAt(sort: Desc), id(sort: Desc)])
}

enum StreakType {
  UNIQUE
  MIXED
  MONO
}

model Streak {
  id        String       @id @default(cuid())
  playerId  String
  player    Player       @relation(fields: [playerId], references: [id])
  games     StreakGame[]
  startedAt DateTime
  endedAt   DateTime?
  length    Int
  isBroken  Boolean
  type      StreakType

  @@index([playerId])
  @@index([length])
  @@index([type])
}

model StreakGame {
  id       String @id
  streakId String
  streak   Streak @relation(fields: [streakId], references: [id], onDelete: Cascade)
  gameId   String
  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([streakId, gameId])
  @@index([gameId])
}

enum HighscoreBreakdown {
  CLASS
  RACE
  CHAR
}

enum HighscoreRuneTier {
  ALL
  THREE_RUNES
  FOUR_PLUS_RUNES
}

model Highscore {
  gameId          String
  game            Game                 @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId        String
  player          Player               @relation(fields: [playerId], references: [id])
  breakdown       HighscoreBreakdown
  runeTier        HighscoreRuneTier
  normalizedClass String
  normalizedRace  String
  char            String
  score           Int
  runes           Int
  rank            Int

  @@id([gameId, breakdown, runeTier])
  @@index([breakdown, runeTier, score(sort: Desc)])
  @@index([playerId])
}

model InvalidGame {
  id        String   @id @default(cuid())
  logfileId String
  logfile   Logfile  @relation(fields: [logfileId], references: [id])
  logLine   String
  missing   String   @default("")
  createdAt DateTime @default(now())
}

model Race {
  name  String  @unique
  abbr  String  @unique @db.Char(2)
  trunk Boolean @default(true)
}

model Class {
  name  String  @unique
  abbr  String  @unique @db.Char(2)
  trunk Boolean @default(true)
}

model God {
  name  String  @unique
  trunk Boolean @default(true)
}
